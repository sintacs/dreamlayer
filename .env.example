# Memoscape environment configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# ------------------------------------------------------------------
# BLE device
# ------------------------------------------------------------------
# Leave blank to auto-scan for the nearest Frame device.
MEMOSCAPE_DEVICE=

# ------------------------------------------------------------------
# Provider: "stub" (no API key needed) or "openai"
# ------------------------------------------------------------------
MEMOSCAPE_PROVIDER=stub

# ------------------------------------------------------------------
# Timeouts & reconnect
# ------------------------------------------------------------------
MEMOSCAPE_SCAN_TIMEOUT=6.0
MEMOSCAPE_LOAD_TIMEOUT=12.0
MEMOSCAPE_RECONNECT_BASE=1.0
MEMOSCAPE_RECONNECT_MAX=30.0
MEMOSCAPE_RECONNECT_TRIES=0

# ------------------------------------------------------------------
# Memory engine
# ------------------------------------------------------------------
MEMOSCAPE_CONFIDENCE=0.60
MEMOSCAPE_FALLBACK=Nothing found nearby.

# ------------------------------------------------------------------
# Logging: DEBUG | INFO | WARNING
# ------------------------------------------------------------------
MEMOSCAPE_LOG_LEVEL=INFO

# ------------------------------------------------------------------
# OpenAI (only needed when MEMOSCAPE_PROVIDER=openai)
# ------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_CONFIDENCE=0.85
