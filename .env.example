# DreamLayer environment configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.
#
# Every variable below is READ BY CODE (single source of truth). Config-tuning
# knobs are applied by Config.from_env() in host-python/src/dreamlayer/config.py;
# runtime knobs are read where noted. An unset variable falls back to the code
# default — env always wins over the default, and there is no third layer.

# ------------------------------------------------------------------
# OpenAI — tier-3 LLM extraction (config.py: Config.from_env)
# ------------------------------------------------------------------
# Only needed when a cloud LLM key is present; the engine degrades gracefully
# (stub extraction) when OPENAI_API_KEY is blank.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Acceptance floor for an LLM-extracted memory (0.0–1.0). Matches the code
# default; out-of-range values are clamped, unparseable values are ignored.
OPENAI_CONFIDENCE=0.60

# ------------------------------------------------------------------
# Memory file (cli.py: the `dreamlayer memories` commands)
# ------------------------------------------------------------------
# Where your memory SQLite lives. Unset -> ~/.dreamlayer/dreamlayer.db.
DREAMLAYER_DB=

# ------------------------------------------------------------------
# Paired Brain (cli.py: plugins install/list, memories over a Brain)
# ------------------------------------------------------------------
DREAMLAYER_BRAIN=
DREAMLAYER_TOKEN=

# ------------------------------------------------------------------
# Privacy Veil (cli.py: browse/export/ember --answers gate)
# ------------------------------------------------------------------
# Set to 1/true/on/yes to refuse memory-reading CLI commands (the veil is up).
DREAMLAYER_VEIL=

# ------------------------------------------------------------------
# Logging (logging_setup.py: configure_logging)
# ------------------------------------------------------------------
# DL_LOG_JSON: 1/true/on/yes -> one JSON line per record; blank/0/false/off/no
# -> plain human logs (default). DL_LOG_LEVEL: DEBUG | INFO | WARNING | ERROR.
DL_LOG_JSON=
DL_LOG_LEVEL=INFO
