{
  "expo": {
    "name": "DreamLayer",
    "slug": "dreamlayer",
    "version": "0.1.0",
    "sdkVersion": "54.0.0",
    "scheme": "dreamlayer",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.letsgettoworkbro.dreamlayer"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.letsgettoworkbro.dreamlayer"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "DreamLayer uses the camera to scan the pairing QR from your Mac mini."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
